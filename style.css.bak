*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --bg: #070710;
  --surface: #0e0e1c;
  --surface2: #151528;
  --accent: #00ff88;
  --accent2: #00c8ff;
  --gold: #ffd700;
  --text: #f0f0ff;
  --muted: #6b6b99;
  --border: #1e1e3a;
  --font: 'Inter', sans-serif;
  --radius: 14px;
}
html, body { height: 100%; background: var(--bg); color: var(--text); font-family: var(--font); overflow: hidden; }
#app { position: relative; width: 100vw; height: 100vh; }

/* ---- TIMELINE BAR ---- */
.timeline-bar {
  position: absolute; top: 0; left: 0; right: 0; z-index: 200;
  height: 36px; background: rgba(7,7,16,0.97); border-bottom: 1px solid var(--border);
  display: flex; align-items: center; gap: 12px; padding: 0 24px;
}
.tl-label { font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.5px; flex-shrink: 0; }
#year-slider { flex: 1; max-width: 380px; accent-color: var(--accent); cursor: pointer; }
.tl-year { font-size: 13px; font-weight: 700; color: var(--accent); min-width: 36px; }

/* ---- HEADER ---- */
#header {
  position: absolute; top: 36px; left: 0; right: 0; z-index: 100;
  display: flex; align-items: center; gap: 10px; padding: 10px 20px;
  background: linear-gradient(to bottom, rgba(7,7,16,0.97) 0%, transparent 100%);
}
.logo { display: flex; align-items: center; gap: 7px; flex-shrink: 0; }
.logo-icon { font-size: 18px; }
.logo-text { font-size: 16px; font-weight: 700; letter-spacing: -0.5px; }
.search-container { position: relative; flex: 1; max-width: 280px; }
#search {
  width: 100%; background: var(--surface); border: 1px solid var(--border);
  border-radius: 10px; padding: 7px 13px; font-size: 13px; color: var(--text);
  font-family: var(--font); outline: none; transition: border-color 0.2s;
}
#search:focus { border-color: var(--accent); }
#search::placeholder { color: var(--muted); }
.suggestions {
  position: absolute; top: calc(100% + 6px); left: 0; right: 0; z-index: 300;
  background: var(--surface2); border: 1px solid var(--border);
  border-radius: 12px; overflow: hidden; box-shadow: 0 8px 32px rgba(0,0,0,0.7); display: none;
}
.suggestions.open { display: block; }
.suggestion-item { padding: 9px 14px; cursor: pointer; font-size: 13px; display: flex; align-items: center; gap: 10px; transition: background 0.15s; }
.suggestion-item:hover { background: var(--border); }
.s-flag { font-size: 15px; } .s-name { font-weight: 500; flex: 1; } .s-nat { font-size: 11px; color: var(--muted); }

.country-nav { display: flex; gap: 5px; }
.country-nav button {
  background: var(--surface); border: 1px solid var(--border); color: var(--text);
  border-radius: 8px; padding: 5px 9px; font-size: 11px; cursor: pointer;
  font-family: var(--font); transition: border-color 0.2s, background 0.2s;
}
.country-nav button:hover { border-color: var(--accent); background: var(--surface2); }

.daily-btn {
  background: linear-gradient(135deg, rgba(255,215,0,0.15), rgba(255,153,0,0.15));
  border: 1px solid rgba(255,215,0,0.35); color: var(--gold);
  border-radius: 10px; padding: 7px 14px; font-size: 12px; font-weight: 600;
  cursor: pointer; font-family: var(--font); flex-shrink: 0;
  transition: background 0.2s, border-color 0.2s;
}
.daily-btn:hover { background: rgba(255,215,0,0.2); border-color: var(--gold); }

.share-btn {
  background: var(--accent); color: #000; border: none; border-radius: 10px;
  padding: 7px 14px; font-size: 12px; font-weight: 600; cursor: pointer;
  font-family: var(--font); flex-shrink: 0; transition: opacity 0.2s;
}
.share-btn:hover { opacity: 0.85; }

/* ---- BREADCRUMB ---- */
.breadcrumb {
  position: absolute; top: 86px; left: 20px; z-index: 110;
  display: flex; align-items: center; gap: 10px;
  background: rgba(14,14,28,0.92); border: 1px solid var(--border);
  border-radius: 10px; padding: 5px 12px; font-size: 12px;
  backdrop-filter: blur(8px);
}
.breadcrumb.hidden { display: none; }
.breadcrumb button { background: none; border: none; color: var(--accent); cursor: pointer; font-family: var(--font); font-size: 12px; }
#bc-text { color: var(--muted); }

/* ---- GLOBE + MAP ---- */
#globe-container { position: absolute; inset: 0; }
#globe-container.fade-out { opacity: 0; transition: opacity 0.4s; }
#map-container { position: absolute; inset: 0; background: #0a0a14; z-index: 5; }

.club-marker {
  width: 44px; height: 44px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 9px; font-weight: 700; color: white; cursor: pointer;
  border: 2px solid rgba(255,255,255,0.25);
  box-shadow: 0 0 14px rgba(0,0,0,0.7);
  transition: transform 0.2s, border-color 0.2s;
  font-family: var(--font); text-align: center; line-height: 1.2;
}
.club-marker:hover { transform: scale(1.22); border-color: #00ff88; }

/* ---- LANDING ---- */
.landing {
  position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
  text-align: center; z-index: 10; transition: opacity 0.4s;
  max-width: 600px; width: 90%;
}
.landing.hidden { opacity: 0; pointer-events: none; }
.landing h2 { font-size: 26px; font-weight: 700; line-height: 1.3; margin-bottom: 8px; }
.landing > p { color: var(--muted); font-size: 14px; margin-bottom: 20px; }
.player-chips { display: flex; flex-wrap: wrap; gap: 7px; justify-content: center; }
.chip {
  background: var(--surface); border: 1px solid var(--border); color: var(--text);
  border-radius: 100px; padding: 6px 13px; font-size: 12px; font-family: var(--font);
  cursor: pointer; transition: border-color 0.2s, background 0.2s;
}
.chip:hover { border-color: var(--accent); background: var(--surface2); }
.game-launch-btn {
  background: linear-gradient(135deg, rgba(255,215,0,0.12), rgba(255,153,0,0.12));
  border: 1px solid rgba(255,215,0,0.3); color: var(--gold);
  border-radius: 14px; padding: 14px 28px; font-size: 15px; font-weight: 700;
  cursor: pointer; font-family: var(--font); width: 100%; max-width: 360px;
  transition: background 0.2s, border-color 0.2s;
}
.game-launch-btn:hover { background: rgba(255,215,0,0.2); border-color: var(--gold); }

/* ---- CLUB CARD ---- */
.club-card {
  position: absolute; top: 86px; left: 20px; z-index: 150;
  background: rgba(14,14,28,0.94); border: 1px solid var(--border);
  border-radius: 18px; padding: 16px; width: 224px;
  backdrop-filter: blur(14px);
  box-shadow: 0 8px 40px rgba(0,0,0,0.7), 0 0 0 1px rgba(0,255,136,0.07);
  transition: opacity 0.3s, transform 0.3s;
}
.club-card.hidden { opacity: 0; pointer-events: none; transform: translateY(-8px); }
.cc-header { display: flex; align-items: center; gap: 10px; margin-bottom: 12px; }
.cc-flag { font-size: 26px; }
.cc-info h3 { font-size: 14px; font-weight: 700; }
.cc-info p { font-size: 10px; color: var(--muted); margin-top: 2px; line-height: 1.4; }
.cc-stats { display: flex; margin-bottom: 13px; }
.cc-stat { flex: 1; text-align: center; }
.cc-stat span { display: block; font-size: 19px; font-weight: 700; color: var(--accent); }
.cc-stat label { font-size: 9px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.5px; }
.cc-deepen {
  width: 100%; background: rgba(0,255,136,0.09); border: 1px solid rgba(0,255,136,0.22);
  color: var(--accent); border-radius: 8px; padding: 7px;
  font-size: 12px; font-weight: 600; cursor: pointer; font-family: var(--font);
  transition: background 0.2s;
}
.cc-deepen:hover { background: rgba(0,255,136,0.18); }

/* ---- TEAMMATES ---- */
.teammates-panel {
  position: absolute; top: 86px; right: 20px; z-index: 150;
  background: rgba(14,14,28,0.94); border: 1px solid var(--border);
  border-radius: 18px; padding: 16px; width: 204px;
  backdrop-filter: blur(14px); box-shadow: 0 8px 40px rgba(0,0,0,0.7);
  transition: opacity 0.3s, transform 0.3s; max-height: 70vh; overflow-y: auto;
}
.teammates-panel.hidden { opacity: 0; pointer-events: none; transform: translateY(-8px); }
.tm-title { font-size: 9px; color: var(--muted); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 2px; }
.tm-era { font-size: 11px; font-weight: 600; color: var(--accent); margin-bottom: 10px; line-height: 1.4; }
.teammates-list { display: flex; flex-direction: column; gap: 5px; }
.teammate-card {
  display: flex; align-items: center; gap: 8px; padding: 6px 9px;
  border-radius: 8px; background: var(--surface); border: 1px solid var(--border);
  font-size: 12px; transition: border-color 0.2s;
}
.teammate-card.clickable { cursor: pointer; }
.teammate-card.clickable:hover { border-color: var(--accent); }
.tm-flag { font-size: 13px; } .tm-name { flex: 1; font-weight: 500; font-size: 11px; } .tm-arrow { font-size: 11px; color: var(--accent); }

/* ---- PLAYER PANEL ---- */
.player-panel {
  position: absolute; bottom: 0; left: 0; right: 0; z-index: 100;
  background: linear-gradient(to top, rgba(7,7,16,0.99) 65%, transparent 100%);
  padding: 14px 20px 18px; transition: opacity 0.4s, transform 0.4s;
}
.player-panel.hidden { opacity: 0; pointer-events: none; transform: translateY(20px); }
.player-header { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; }
.player-flag { font-size: 30px; }
.player-info { flex: 1; }
.player-info h1 { font-size: 17px; font-weight: 700; }
.player-info p { color: var(--muted); font-size: 12px; margin-top: 2px; }
.nt-btn {
  display: inline-flex; align-items: center; gap: 4px;
  background: rgba(0,200,255,0.09); border: 1px solid rgba(0,200,255,0.28);
  color: var(--accent2); border-radius: 8px; padding: 3px 9px;
  font-size: 11px; font-weight: 600; cursor: pointer; font-family: var(--font);
  margin-top: 4px; transition: background 0.2s;
}
.nt-btn:hover { background: rgba(0,200,255,0.18); }
.player-stats-summary { display: flex; gap: 12px; }
.stat-pill { text-align: center; }
.stat-pill span { font-size: 17px; font-weight: 700; color: var(--accent); display: block; }
.stat-pill label { font-size: 9px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.5px; }
.nav-row { display: flex; align-items: center; gap: 7px; }
.nav-btn {
  background: var(--surface2); border: 1px solid var(--border); color: var(--text);
  border-radius: 8px; width: 30px; height: 30px; font-size: 13px;
  cursor: pointer; font-family: var(--font); flex-shrink: 0; transition: border-color 0.2s;
}
.nav-btn:hover:not(:disabled) { border-color: var(--accent); }
.nav-btn:disabled { opacity: 0.3; cursor: default; }
.nav-label-row { text-align: center; margin-top: 3px; }
#nav-label { font-size: 10px; color: var(--muted); }
.career-timeline { display: flex; gap: 0; overflow-x: auto; flex: 1; scrollbar-width: none; padding: 4px 0; }
.career-timeline::-webkit-scrollbar { display: none; }
.timeline-item {
  display: flex; flex-direction: column; align-items: center;
  min-width: 66px; cursor: pointer; padding: 0 3px;
  opacity: 0; animation: fadeInUp 0.4s forwards;
}
.timeline-item.active .ti-dot { background: #fff; box-shadow: 0 0 14px rgba(0,255,136,0.9); transform: scale(1.5); }
.timeline-item.active .ti-club { color: var(--accent); }
.timeline-item:hover .ti-dot { transform: scale(1.3); }
.ti-flag { font-size: 11px; margin-bottom: 3px; }
.ti-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--accent); transition: all 0.2s; margin-bottom: 3px; }
.timeline-connector { width: 28px; height: 2px; background: linear-gradient(to right, rgba(0,255,136,0.4), rgba(0,200,255,0.4)); align-self: center; margin-bottom: 12px; flex-shrink: 0; }
.ti-club { font-size: 8px; font-weight: 600; text-align: center; color: var(--text); margin-bottom: 1px; line-height: 1.2; }
.ti-years { font-size: 7px; color: var(--muted); text-align: center; }
@keyframes fadeInUp { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }

/* ---- CLUB VIEW / NATIONAL VIEW ---- */
.club-view, .national-view {
  position: absolute; inset: 36px 0 0 0; z-index: 160;
  background: rgba(7,7,16,0.97); overflow-y: auto; padding: 14px 20px 24px;
  animation: slideUp 0.28s ease;
}
.club-view.hidden, .national-view.hidden { display: none; }
@keyframes slideUp { from { transform: translateY(18px); opacity: 0; } to { transform: none; opacity: 1; } }
.panel-close {
  background: none; border: 1px solid var(--border); color: var(--muted);
  border-radius: 8px; padding: 5px 11px; font-size: 12px; cursor: pointer;
  font-family: var(--font); margin-bottom: 14px; transition: border-color 0.2s;
}
.panel-close:hover { border-color: var(--accent); color: var(--text); }
.cv-layout, .nv-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 28px; }
.cv-left h2, .nv-left h2 { font-size: 26px; font-weight: 700; margin-bottom: 4px; }
.cv-meta { font-size: 12px; color: var(--muted); margin-bottom: 4px; }
.cv-section { margin-top: 18px; }
.cv-section h4, .nv-left .cv-section h4 { font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: var(--muted); margin-bottom: 7px; }
.cv-section p { font-size: 13px; line-height: 1.6; color: var(--text); }
.cv-section ul { list-style: none; }
.cv-section ul li { font-size: 12px; padding: 4px 0; border-bottom: 1px solid var(--border); color: var(--text); }
.cv-right h4, .nv-right h4 { font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: var(--muted); margin-bottom: 10px; }
.squad-list { display: flex; flex-direction: column; gap: 5px; }
.squad-card {
  display: flex; align-items: center; gap: 10px; padding: 9px 12px;
  border-radius: 10px; background: var(--surface); border: 1px solid var(--border);
  transition: border-color 0.2s;
}
.squad-card.clickable { cursor: pointer; }
.squad-card.clickable:hover { border-color: var(--accent); background: var(--surface2); }
.sq-flag { font-size: 17px; } .sq-info { flex: 1; } .sq-name { display: block; font-size: 13px; font-weight: 600; }
.sq-pos { font-size: 11px; color: var(--muted); } .sq-arrow { color: var(--accent); font-size: 13px; }

/* ---- NATIONAL TEAM VIEW ---- */
.nt-tournament { display: grid; grid-template-columns: auto 1fr; gap: 3px 12px; padding: 9px 0; border-bottom: 1px solid var(--border); }
.nt-result { font-size: 13px; font-weight: 700; grid-column: 1; }
.nt-comp { font-size: 12px; color: var(--text); grid-column: 2; }
.nt-scorer { font-size: 11px; color: var(--muted); grid-column: 2; }
.greats-list { display: flex; flex-wrap: wrap; gap: 7px; }
.nt-great { background: var(--surface); border: 1px solid var(--border); border-radius: 100px; padding: 4px 11px; font-size: 12px; }
.nt-great.clickable { cursor: pointer; }
.nt-great.clickable:hover { border-color: var(--accent); color: var(--accent); }

/* ---- DEEP DIVE ---- */
.deep-dive { position: absolute; inset: 0; z-index: 300; background: rgba(7,7,16,0.87); backdrop-filter: blur(10px); display: flex; align-items: center; justify-content: center; }
.deep-dive.hidden { display: none; }
.dd-inner { background: var(--surface2); border: 1px solid var(--border); border-radius: 22px; padding: 26px; max-width: 460px; width: 90%; position: relative; max-height: 82vh; overflow-y: auto; box-shadow: 0 24px 80px rgba(0,0,0,0.85); }
.dd-close { position: absolute; top: 13px; right: 16px; background: none; border: none; color: var(--muted); font-size: 20px; cursor: pointer; }
.dd-inner h2 { font-size: 19px; font-weight: 700; margin-bottom: 3px; }
.dd-period { font-size: 12px; color: var(--muted); margin-bottom: 16px; }
.dd-stats { display: flex; margin-bottom: 18px; background: var(--surface); border-radius: 10px; padding: 13px; }
.dd-stats div { flex: 1; text-align: center; }
.dd-stats span { display: block; font-size: 21px; font-weight: 700; color: var(--accent); }
.dd-stats label { font-size: 10px; color: var(--muted); text-transform: uppercase; }
.dd-section { margin-bottom: 16px; }
.dd-section h4 { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; color: var(--muted); margin-bottom: 6px; }
.dd-section p { font-size: 13px; line-height: 1.65; }

/* ---- DAILY GAME PANEL ---- */
.game-panel {
  position: absolute; top: 36px; right: 0; bottom: 0; z-index: 250;
  width: 360px; background: rgba(7,7,16,0.97);
  border-left: 1px solid var(--border);
  backdrop-filter: blur(16px);
  display: flex; flex-direction: column;
  animation: slideInRight 0.28s ease;
  overflow-y: auto;
}
.game-panel.hidden { display: none; }
@keyframes slideInRight { from { transform: translateX(30px); opacity: 0; } to { transform: none; opacity: 1; } }
.game-inner { padding: 20px; display: flex; flex-direction: column; gap: 16px; flex: 1; }
.game-header { display: flex; align-items: flex-start; justify-content: space-between; }
.game-title { font-size: 20px; font-weight: 700; color: var(--gold); }
.game-hint { font-size: 12px; color: var(--muted); margin-top: 4px; }
.game-exit-btn { background: none; border: 1px solid var(--border); color: var(--muted); border-radius: 8px; padding: 5px 10px; font-size: 12px; cursor: pointer; font-family: var(--font); transition: border-color 0.2s; }
.game-exit-btn:hover { border-color: var(--accent); color: var(--text); }
.game-instructions { font-size: 12px; color: var(--muted); line-height: 1.6; }
#game-input {
  width: 100%; background: var(--surface); border: 1px solid var(--border);
  border-radius: 10px; padding: 10px 14px; font-size: 13px; color: var(--text);
  font-family: var(--font); outline: none; transition: border-color 0.2s;
}
#game-input:focus { border-color: var(--gold); }
.game-feedback { font-size: 12px; color: var(--muted); min-height: 16px; }
.game-guesses-list { display: flex; flex-direction: column; gap: 6px; max-height: 200px; overflow-y: auto; }
.game-guess-item {
  padding: 8px 12px; border-radius: 8px; font-size: 13px; font-weight: 500;
  border: 1px solid var(--border);
}
.game-guess-item.correct { background: rgba(0,255,136,0.12); border-color: rgba(0,255,136,0.4); color: var(--accent); }
.game-guess-item.wrong { background: rgba(255,80,80,0.08); border-color: rgba(255,80,80,0.25); color: #ff8888; }
.game-result { display: flex; flex-direction: column; gap: 14px; }
.game-result.hidden { display: none; }
.game-result-title { font-size: 22px; font-weight: 700; color: var(--accent); }
.game-result-subtitle { font-size: 13px; color: var(--muted); }
.game-result-career { font-size: 22px; letter-spacing: 2px; }
.game-result-guesses { font-size: 13px; color: var(--gold); font-weight: 600; }
.game-share-box { display: flex; flex-direction: column; gap: 8px; }
.game-share-text {
  background: var(--surface); border: 1px solid var(--border); border-radius: 10px;
  padding: 10px 12px; font-size: 12px; color: var(--text); font-family: var(--font);
  resize: none; line-height: 1.6;
}
.game-share-copy {
  background: var(--gold); color: #000; border: none; border-radius: 10px;
  padding: 9px; font-size: 13px; font-weight: 700; cursor: pointer; font-family: var(--font);
  transition: opacity 0.2s;
}
.game-share-copy:hover { opacity: 0.85; }
.game-see-career {
  background: rgba(0,255,136,0.1); border: 1px solid rgba(0,255,136,0.25);
  color: var(--accent); border-radius: 10px; padding: 10px;
  font-size: 13px; font-weight: 600; cursor: pointer; font-family: var(--font);
  transition: background 0.2s; text-align: center;
}
.game-see-career:hover { background: rgba(0,255,136,0.2); }

/* ---- RESPONSIVE ---- */
@media (max-width: 768px) {
  .teammates-panel, .country-nav { display: none; }
  .cv-layout, .nv-layout { grid-template-columns: 1fr; }
  .landing h2 { font-size: 20px; }
  #header { padding: 8px 12px; gap: 8px; }
  .player-panel { padding: 10px 14px 14px; }
  .game-panel { width: 100%; top: auto; bottom: 0; height: 70vh; border-left: none; border-top: 1px solid var(--border); }
}
